<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <ImageView
        android:id="@+id/imageWelcomePopup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/home_welcome_image"
        android:scaleType="fitCenter"
        android:src="@drawable/new_welcome" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonCloseWelcome"
        style="@style/Widget.Bayyari.Button.Primary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="14dp"
        android:minWidth="72dp"
        android:text="@string/action_exit"
        app:icon="@drawable/ic_arrow_back"
        app:iconGravity="textStart"
        app:iconTint="@color/colorOnPrimary" />
</FrameLayout>
