<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="138dp"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardBackgroundColor="@color/colorCard"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="10dp"
        android:paddingTop="18dp"
        android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/imageLogo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginBottom="10dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:contentDescription="@string/nav_live" />

        <TextView
            android:id="@+id/textChannelName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/colorTextPrimary"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="BeIN Sports 1" />

        <TextView
            android:id="@+id/textProgram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/colorTextSecondary"
            android:textSize="10sp"
            tools:text="Champions League" />

        <LinearLayout
            android:id="@+id/livePill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_pill_live"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="9dp"
            android:paddingVertical="3dp">

            <View
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:layout_marginEnd="4dp"
                android:background="@color/colorAccentLive" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="LIVE"
                android:textColor="@color/colorAccentLive"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressEpg"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="10dp"
            android:indeterminate="false"
            android:progress="0"
            android:visibility="gone" />
    </LinearLayout>

</androidx.cardview.widget.CardView>
