<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Left: category list ~20% -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCategories"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.20" />

    <View
        android:id="@+id/divider1"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="@color/colorOutline"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/recyclerCategories"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Middle: channel panel ~38% (header + search + list) -->
    <LinearLayout
        android:id="@+id/channelPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/divider1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.38">

        <!-- Channel panel header -->
        <LinearLayout
            android:id="@+id/liveHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="8dp"
            android:paddingTop="14dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/textLiveCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/colorTextPrimary"
                android:textSize="13sp"
                tools:text="All (2,400)" />

            <ImageButton
                android:id="@+id/buttonLiveSort"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_iconbtn_circle"
                android:clickable="true"
                android:contentDescription="@string/live_sort"
                android:focusable="true"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_settings" />

            <ImageButton
                android:id="@+id/buttonLiveSearch"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_iconbtn_circle"
                android:contentDescription="@string/nav_search"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_search" />
        </LinearLayout>

        <!-- Collapsible search -->
        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchLive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_input_field"
            android:queryHint="@string/search_hint"
            android:visibility="gone"
            app:closeIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:iconifiedByDefault="false" />

        <!-- Channel list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerChannels"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:overScrollMode="never" />

    </LinearLayout>

    <View
        android:id="@+id/divider2"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="@color/colorOutline"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/channelPanel"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Right: preview card fills remaining space -->
    <androidx.cardview.widget.CardView
        android:id="@+id/previewCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="@dimen/page_edge"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="@color/colorSurface"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/divider2"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Video preview -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.media3.ui.PlayerView
                    android:id="@+id/previewPlayerView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_hero_gradient"
                    android:keepScreenOn="true"
                    app:use_controller="false" />
            </FrameLayout>

            <!-- Info + actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/textPreviewTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    tools:text="BEIN SPORTS 1" />

                <TextView
                    android:id="@+id/textPreviewMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp"
                    tools:text="Sports" />

                <!-- Action buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="end"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonCatchUp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginEnd="6dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="10dp"
                        android:text="@string/live_catchup"
                        android:textSize="11sp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonEpg"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginEnd="6dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="10dp"
                        android:text="@string/live_epg"
                        android:textSize="11sp" />

                    <ImageButton
                        android:id="@+id/buttonFavorite"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_iconbtn_circle"
                        android:contentDescription="@string/live_add_favorite"
                        android:padding="9dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_favorites" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonAddFav"
                        style="@style/Widget.Bayyari.Button.Primary"
                        android:layout_width="96dp"
                        android:layout_height="38dp"
                        android:includeFontPadding="false"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="14dp"
                        android:paddingTop="0dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="0dp"
                        android:text="@string/movie_play"
                        android:textAllCaps="false"
                        android:textColor="@color/colorOnPrimary"
                        android:textSize="12sp"
                        app:icon="@drawable/ic_play_solid"
                        app:iconGravity="textStart"
                        app:iconPadding="5dp"
                        app:iconSize="12dp"
                        app:iconTint="@color/colorOnPrimary" />

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
