<navigation
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
android:id="@+id/nav_graph"
app:startDestination="@id/homeFragment" >
<fragment
    android:id="@+id/homeFragment"
    android:name="com.bayyari.tv.ui.home.HomeFragment"
    android:label="@string/nav_home" />
<fragment
    android:id="@+id/liveFragment"
    android:name="com.bayyari.tv.ui.live.LiveFragment"
    android:label="@string/nav_live" >

    <action
        android:id="@+id/action_live_to_epg"
        app:destination="@id/epgFragment" />
    <action
        android:id="@+id/action_live_to_catchup"
        app:destination="@id/catchUpFragment" />

</fragment>
<fragment
    android:id="@+id/movieFragment"
    android:name="com.bayyari.tv.ui.movies.MovieFragment"
    android:label="@string/nav_movies" >

    <action
        android:id="@+id/action_movie_to_detail"
        app:destination="@id/movieDetailFragment" />

</fragment>
<fragment
    android:id="@+id/movieDetailFragment"
    android:name="com.bayyari.tv.ui.movies.MovieDetailFragment"
    android:label="@string/nav_movies" />
<fragment
    android:id="@+id/seriesFragment"
    android:name="com.bayyari.tv.ui.series.SeriesFragment"
    android:label="@string/nav_series" >

    <action
        android:id="@+id/action_series_to_detail"
        app:destination="@id/seriesDetailFragment" />

</fragment>
<fragment
    android:id="@+id/seriesDetailFragment"
    android:name="com.bayyari.tv.ui.series.SeriesDetailFragment"
    android:label="@string/nav_series" >

    <action
        android:id="@+id/action_series_to_season"
        app:destination="@id/seasonFragment" />

</fragment>
<fragment
    android:id="@+id/seasonFragment"
    android:name="com.bayyari.tv.ui.series.SeasonFragment"
    android:label="@string/nav_series" />
<fragment
    android:id="@+id/searchFragment"
    android:name="com.bayyari.tv.ui.search.SearchFragment"
    android:label="@string/nav_search" />
<fragment
    android:id="@+id/favoritesFragment"
    android:name="com.bayyari.tv.ui.favorites.FavoritesFragment"
    android:label="@string/nav_favorites" />
<fragment
    android:id="@+id/settingsFragment"
    android:name="com.bayyari.tv.ui.settings.SettingsFragment"
    android:label="@string/nav_settings" >

    <action
        android:id="@+id/action_settings_to_server_manager"
        app:destination="@id/serverManagerFragment" />

</fragment>
<fragment
    android:id="@+id/serverManagerFragment"
    android:name="com.bayyari.tv.ui.settings.ServerManagerFragment"
    android:label="@string/settings_servers" />
<fragment
    android:id="@+id/epgFragment"
    android:name="com.bayyari.tv.ui.live.EpgFragment"
    android:label="@string/live_epg" />
<fragment
    android:id="@+id/catchUpFragment"
    android:name="com.bayyari.tv.ui.catchup.CatchUpFragment"
    android:label="@string/nav_catchup" />
</navigation>