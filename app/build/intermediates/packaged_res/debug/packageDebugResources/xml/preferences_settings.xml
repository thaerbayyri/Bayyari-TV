<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <Preference
        android:key="pref_change_playlist"
        android:title="@string/settings_change_playlist"
        android:summary="@string/settings_change_playlist_summary" />

    <Preference
        android:key="pref_servers"
        android:title="@string/settings_servers"
        android:summary="@string/settings_servers_summary" />

    <ListPreference
        android:key="pref_default_player"
        android:title="@string/settings_default_player"
        android:entries="@array/player_entries"
        android:entryValues="@array/player_values"
        android:defaultValue="internal" />

    <ListPreference
        android:key="pref_stream_format"
        android:title="@string/settings_stream_format"
        android:entries="@array/stream_entries"
        android:entryValues="@array/stream_values"
        android:defaultValue="hls" />

    <ListPreference
        android:key="pref_buffer_size"
        android:title="@string/settings_buffer"
        android:entries="@array/buffer_entries"
        android:entryValues="@array/buffer_values"
        android:defaultValue="30000" />

    <SwitchPreferenceCompat
        android:key="pref_auto_play_next"
        android:title="@string/settings_auto_play_next"
        android:defaultValue="true" />

    <Preference
        android:key="pref_clear_cache"
        android:title="@string/settings_clear_cache" />

    <Preference
        android:key="pref_app_info"
        android:title="@string/settings_app_info" />

    <Preference
        android:key="pref_app_version"
        android:title="@string/settings_app_version_title" />

    <Preference
        android:key="pref_check_update"
        android:title="@string/settings_check_update"
        android:summary="@string/settings_check_update_summary" />

    <EditTextPreference
        android:key="pref_parental_pin"
        android:title="@string/settings_parental_pin" />

    <Preference
        android:key="pref_restore_hidden_categories"
        android:title="@string/settings_restore_hidden_categories"
        android:summary="@string/settings_restore_hidden_categories_summary" />

</PreferenceScreen>
